Options -Indexes
RewriteEngine On

# Pass Authorization header to PHP — Apache strips it on CGI/FastCGI.
# The SetEnvIf approach is most reliable across Apache versions.
SetEnvIf Authorization "(.+)" HTTP_AUTHORIZATION=$1

# Allow direct access to real files (css, js, images, etc.)
RewriteCond %{REQUEST_FILENAME} -f
RewriteRule ^ - [L]

# Allow direct access to real directories
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# Route everything else through index.php
RewriteRule ^ index.php [L]
